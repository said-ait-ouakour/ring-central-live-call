# ─────────────────────────────────────────────────
# RingCentral REST API Credentials
# Used for Supervise API calls and device lookup
# ─────────────────────────────────────────────────
RC_CLIENT_ID=your_ringcentral_client_id
RC_CLIENT_SECRET=your_ringcentral_client_secret
RC_SERVER_URL=https://platform.ringcentral.com
RC_JWT_TOKEN=your_ringcentral_jwt_token

# ─────────────────────────────────────────────────
# RingCentral SIP Softphone (optional on most hosts)
# By default the bridge loads SIP settings from the RingCentral API using
# RC_SUPERVISOR_DEVICE_ID (same source as the admin "SIP" provisioning page).
# Set the variables below only if the API is unavailable or you need a manual override.
# SIP_OUTBOUND_REGION selects outboundProxies[].region (default NA).
# ─────────────────────────────────────────────────
# SIP_OUTBOUND_REGION=NA
# SIP_INFO_DOMAIN=sip.ringcentral.com
# SIP_INFO_OUTBOUND_PROXY=sip20.ringcentral.com:5096
# SIP_INFO_USERNAME=your_sip_username
# SIP_INFO_PASSWORD=your_sip_password
# SIP_INFO_AUTHORIZATION_ID=your_sip_authorization_id

# ─────────────────────────────────────────────────
# RingCentral Supervisor Info
# The extension that will supervise (listen to) calls
# The device ID of the softphone registered above
# ─────────────────────────────────────────────────
RC_SUPERVISOR_EXTENSION_ID=your_supervisor_extension_id
RC_SUPERVISOR_DEVICE_ID=your_supervisor_device_id

# ─────────────────────────────────────────────────
# RingCentral Webhook / Auto-detection (optional but recommended)
#
# RC_WEBHOOK_URL: The publicly reachable base URL of this bridge server.
#   e.g. https://your-bridge.onrender.com  (no trailing slash)
#   RingCentral will POST call events to {RC_WEBHOOK_URL}/webhook/ringcentral
#   Leave blank to disable auto-detection (manual /api/supervise only).
#
# RC_MONITORED_EXTENSION_ID: The agent extension whose calls should be
#   automatically supervised. If blank, ALL account calls are monitored.
# ─────────────────────────────────────────────────
RC_WEBHOOK_URL=https://your-bridge-url.onrender.com
RC_MONITORED_EXTENSION_ID=your_agent_extension_id

# ─────────────────────────────────────────────────
# AssemblyAI
# ─────────────────────────────────────────────────
ASSEMBLYAI_API_KEY=your_assemblyai_api_key

# ─────────────────────────────────────────────────
# Bridge Server
# ─────────────────────────────────────────────────
PORT=3100
BRIDGE_API_KEY=generate-a-strong-random-key-here

# ─────────────────────────────────────────────────
# CRM URL (for CORS whitelist)
# ─────────────────────────────────────────────────
CRM_URL=http://localhost:3000
